<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- 灵动岛容器（收起状态） -->
    <FrameLayout
        android:id="@+id/islandContainer"
        android:layout_width="120dp"
        android:layout_height="40dp"
        android:background="@drawable/island_shape"
        android:elevation="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🎮 林默"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

    </FrameLayout>

    <!-- 展开面板 -->
    <LinearLayout
        android:id="@+id/expandedPanel"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:background="@drawable/panel_shape"
        android:elevation="16dp"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <!-- 标题栏 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/statusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="林默注入器"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnClose"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/close_button_shape"
                android:text="×"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

        </RelativeLayout>

        <!-- 分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- 导入功能按钮 -->
        <Button
            android:id="@+id/btnImport"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/import_button_shape"
            android:text="📥 导入功能"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- 导入原版按钮 -->
        <Button
            android:id="@+id/btnImportOriginal"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="#162447"
            android:text="🔄 导入原版"
            android:textColor="#AAAAAA"
            android:textSize="14sp" />

        <!-- 提示文字 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="音量- 可关闭此面板"
            android:textColor="#666666"
            android:textSize="11sp" />

    </LinearLayout>

</FrameLayout>
